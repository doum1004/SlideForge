# ─── Puppeteer / Rendering ─────────────────────────────────────────────
# Chrome/Chromium executable path for Puppeteer (optional, auto-detected)
CHROME_PATH=

# ─── Defaults ─────────────────────────────────────────────────────────
# Default theme name (defaults to "default")
# DEFAULT_THEME=default

# Author / brand shown in the bottom bar of every slide (defaults to "@SlideForge")
# DEFAULT_AUTHOR=@SlideForge

# ─── MCP Server Transport (optional) ──────────────────────────────────
# Transport mode for src/mcp-server.ts: stdio | http | sse
# MCP_TRANSPORT=stdio
# Host/port for HTTP/SSE modes
# MCP_HOST=127.0.0.1
# MCP_PORT=3000
# Endpoint paths for network transports
# MCP_PATH=/mcp
# MCP_SSE_PATH=/sse
# MCP_MESSAGES_PATH=/messages
